{
  "name": "TechLab Backend Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-spring-boot-dashboard",
        "vmware.vscode-spring-boot-tooling",
        "vscjava.vscode-lombok" // Si usas Lombok, es vital
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-17",
            "path": "/usr/local/sdkman/candidates/java/current"
          }
        ]
      }
    }
  },
  // Reenvía el puerto del backend para que puedas probar la API en el navegador local
  "forwardPorts": [8080, 5005],
  
  // IMPORTANTE: Sustituye 'simpleshop_default' por el nombre que viste en 'docker network ls'
  "runArgs": [
    "--network", "simpleshop_default"
  ],

  "remoteUser": "vscode"
}